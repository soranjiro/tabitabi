{
  "name": "tabitabi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "旅のしおり管理アプリ",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "deploy": "turbo deploy",
    "deploy:api": "pnpm --filter api deploy",
    "deploy:web": "pnpm --filter web deploy",
    "test": "turbo test:run",
    "test:api": "pnpm --filter api test:run",
    "test:web": "pnpm --filter web test:run",
    "prepare": "husky"
  },
  "devDependencies": {
    "chrome-launcher": "^1.2.1",
    "husky": "^9.1.7",
    "lighthouse": "^13.3.0",
    "turbo": "^2.9.14",
    "wrangler": "4.83.0"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.6",
      "cookie": "1.1.1",
      "esbuild@<0.25.0": "0.25.12",
      "miniflare": "4.20260415.0",
      "undici": "7.25.0",
      "vite": "6.4.2",
      "wrangler": "4.83.0"
    }
  }
}
